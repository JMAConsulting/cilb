<?xml version="1.0"?>
<extension key="changenotificationreceipt" type="module">
  <file>changenotificationreceipt</file>
  <name>Change Notification Receipt</name>
  <description>Watches CILB contact, participant and contribution records for changes, queues them, and emails an updated receipt (PDF) nightly to the affected contact.</description>
  <license>AGPL-3.0</license>
  <authors>
    <author>
      <name>Edsel Lopez</name>
      <email>edsel.lopez@jmaconsulting.biz</email>
      <role>Maintainer</role>
    </author>
  </authors>
  <urls>
    <url desc="Licensing">https://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-05-29</releaseDate>
  <version>1.0.0</version>
  <develStage>alpha</develStage>
  <compatibility mode="semver">
    <ver>6.8</ver>
  </compatibility>
  <php_compatibility mode="list">
    <ver>8.0</ver>
    <ver>8.1</ver>
    <ver>8.2</ver>
    <ver>8.3</ver>
  </php_compatibility>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/ChangeNotificationReceipt</namespace>
    <format>25.10.1</format>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>entity-types-php@2.0.0</mixin>
  </mixins>
</extension>
